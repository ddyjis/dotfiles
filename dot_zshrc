# Set up starship
eval "$(starship init zsh)"

# Zoxide
eval "$(zoxide init zsh)"

# Utilities
function mkcd () {
  mkdir -p -- "$1" && cd -P -- "$1"
}

# Aliases
alias ..='cd ..'
alias ~='cd ~'

alias ls='eza'
alias ll='eza -lbF --git'
alias lla='eza -lbha --time-style=long-iso --git'

alias reload='source ~/.zshrc'

# Environment Variables
export XDG_CONFIG_HOME="$HOME/.config"

# Warn if .zprofile modifies PATH
if grep -qE '^\s*(export PATH|path\+=|path=\()' ~/.zprofile 2>/dev/null; then
    echo "warning: ~/.zprofile contains PATH modifications — consider moving them to .zshrc"
fi

# Helper to safely add to PATH
# Usage: add_path /some/dir          # prepend (default, higher priority)
#        add_path /some/dir append   # append (lower priority)
add_path() {
    local dir="$1"
    local mode="${2:-prepend}"

    [[ -d "$dir" ]] || return  # skip if directory doesn't exist

    # skip if already in PATH
    [[ ":$PATH:" == *":$dir:"* ]] && return

    if [[ "$mode" == "append" ]]; then
        export PATH="$PATH:$dir"
    else
        export PATH="$dir:$PATH"
    fi
}

